# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, private secrets, and external secret values
*.tfvars
*.tfvars.json

# Ignore override files as they may contain local-only configurations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfvars example
!terraform.tfvars.example

# Windows files
Thumbs.db
ehthumbs.db
Desktop.ini
